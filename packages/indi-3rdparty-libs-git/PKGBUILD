# Maintainer: Mattia Procopio (astro.matto) <matto.astro at gmail dot com>
pkgname=indi-3rdparty-libs-git
pkgver=r188.1b017c2
pkgrel=1
pkgdesc="Indi 3rd party libraries"
provides=(indi-3rdparty-libs)
conflicts=(indi-3rdparty-libs)
arch=(x86_64 aarch64)
url="https://indilib.org"
license=('LGPLv2')
depends=('libindi' 'ffmpeg' 'libgphoto2' 'pipewire-jack' 'wireplumber')
makedepends=(cmake)
source=("indi-3rdparty::git+https://github.com/indilib/indi-3rdparty.git")
sha256sums=(SKIP)

pkgver() {
  cd indi-3rdparty
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  mkdir -p build
}

build() {
  cd build
  cmake -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Debug \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DBUILD_LIBS=1 \
        ../indi-3rdparty
  make
}

package() {
  cd build
  make DESTDIR="$pkgdir" install

}
