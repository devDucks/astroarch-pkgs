# Maintainer: Mattia Procopio (astro.matto) <matto.astro at gmail dot com>
pkgname=astromonitor
pkgver=2.0.0
pkgrel=1
pkgdesc="Small utility to help you in your astrophotography journey"
arch=(x86_64 aarch64)
url=https://github.com/MattBlack85/astro_monitor
license=(MIT)
depends=(gcc-libs)
makedepends=(rustup)
source=(https://github.com/MattBlack85/astro_monitor/archive/refs/tags/v${pkgver}-rc2.tar.gz)
sha256sums=(f6c55f1919df7780d30975d8ac68ea6c6d08a2fe574b25246e99287ef5383726)
_folder=${srcdir}/astro_monitor-${pkgver}

build() {
    cd ${srcdir}/astro_monitor-${pkgver}-rc2
    # Clear Arch CFLAGS: they are passed to ring's C compiler via the cc crate and
    # cause silent compilation failure on Ubuntu (FORTIFY_SOURCE redefinition +
    # -Werror=format-security). Rust code is unaffected by CFLAGS.
    CFLAGS="" CXXFLAGS="" cargo build --release
}

package() {
    mkdir -p ${pkgdir}/usr/bin/
    
    mv ${srcdir}/astro_monitor-${pkgver}-rc2/target/release/astromonitor ${pkgdir}/usr/bin
}
