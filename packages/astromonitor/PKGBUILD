# Maintainer: Mattia Procopio (astro.matto) <matto.astro at gmail dot com>
pkgname=astromonitor
pkgver=2.0.0
pkgrel=1
pkgdesc="Small utility to help you in your astrophotography journey"
arch=(x86_64 aarch64)
url=https://github.com/MattBlack85/astro_monitor
license=(MIT)
depends=(gcc-libs)
makedepends=(rustup)
source=(https://github.com/MattBlack85/astro_monitor/archive/refs/tags/v${pkgver}-rc1.tar.gz)
sha256sums=(aaaa17a795109c573fe5f3a11352475cabb2a0a790c0ee5864263929abdbac98)
_folder=${srcdir}/astro_monitor-${pkgver}

build() {
    cd ${srcdir}/astro_monitor-${pkgver}-rc1
    # ring 0.16.x is incompatible with rust-lld; force GNU BFD linker
    RUSTFLAGS="${RUSTFLAGS} -C link-arg=-fuse-ld=bfd" cargo build --release
}

package() {
    mkdir -p ${pkgdir}/usr/bin/
    
    mv ${srcdir}/astro_monitor-${pkgver}-rc1/target/release/astromonitor ${pkgdir}/usr/bin
}
