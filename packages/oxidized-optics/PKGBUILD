# Maintainer: Mattia Procopio (astro.matto) <matto.astro at gmail dot com>
pkgname=oxidized-optics
pkgver=0.1.0
pkgrel=1
pkgdesc="Newtonian collimator"
arch=(x86_64 aarch64)
url=https://github.com/devDucks/rcoll
license=(GPLv3)
depends=(gcc-libs)
makedepends=(rustup)
source=(https://github.com/devDucks/rcoll/archive/refs/tags/v${pkgver}.tar.gz)
sha256sums=(1)

build() {
    cd ${srcdir}/${pkgname}-${pkgver}
    # Clear Arch CFLAGS: they are passed to ring's C compiler via the cc crate and
    # cause silent compilation failure on Ubuntu (FORTIFY_SOURCE redefinition +
    # -Werror=format-security). Rust code is unaffected by CFLAGS.
    CFLAGS="" CXXFLAGS="" cargo build --release
}

package() {
    mkdir -p ${pkgdir}/usr/bin/
    mkdir -p ${pkgdir}/usr/share/applications
    mkdir -p ${pkgdir}/usr/share/icons/hicolor/scalable/apps/

    install -Dm644 ${srcdir}/${pkgname}-${pkgver}/logo.svg ${pkgdir}/usr/share/icons/hicolor/scalable/apps/rcoll.svg
    install -Dm644 ${srcdir}/${pkgname}-${pkgver}/packaging/crabula.desktop ${pkgdir}/usr/share/applications/oxidized-optics.desktop
    install -Dm755 ${srcdir}/${pkgname}-${pkgver}/target/release/rcoll ${pkgdir}/usr/bin/oxidized-optics
}
