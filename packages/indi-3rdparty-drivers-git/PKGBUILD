# Maintainer: Mattia Procopio (astro.matto) <matto.astro at gmail dot com>
pkgname=indi-3rdparty-drivers-git
pkgver=r188.1b017c2
pkgrel=1
pkgdesc="Indi 3rd party drivers"
arch=(x86_64 aarch64)
url="https://indilib.org"
provides=(indi-3rdparty-drivers)
conflicts=(indi-3rdparty-drivers)
license=('LGPLv2')
depends=('indi-3rdparty-libs' 'limesuite' 'libdc1394' 'fxload' 'zeromq' 'urjtag' 'dfu-util' 'libxisf')
makedepends=(cmake)
source=("indi-3rdparty::git+https://github.com/indilib/indi-3rdparty.git")
sha256sums=(SKIP)

pkgver() {
  cd indi-3rdparty
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  mkdir -p build
}

build() {
  cd build
  cmake -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Debug \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
        -DSKIP_SETCAP=true \
        ../indi-3rdparty
  make
}

package() {
  cd build
  make DESTDIR="$pkgdir" install
}
