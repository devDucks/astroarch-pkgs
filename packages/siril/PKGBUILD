pkgname=siril
pkgver=1.4.2
pkgrel=1
pkgdesc="An astronomical image processing software for Linux. (IRIS clone)"
arch=('aarch64' 'x86_64')
license=('GPL3')
depends=(cfitsio
         exiv2
         ffms2
         fftw
         gsl
         gtk3
         gtksourceview4
         gvfs
         json-glib
         lcms2
         libgit2
         libheif
         libjpeg
         libjxl
         libpng
         libraw
         libtiff
         libtiff
         libxisf
         opencv
         wcslib)
makedepends=(cmake
             meson
             ninja)
optdepends=('ffmpeg: For AVI export')
options=(!lto)

source=("https://free-astro.org/download/siril-${pkgver}.tar.bz2")
sha256sums=('451915627ae461ef992ac0f83bd3ff1db5102d72ca379eee55b9be4f12b1162b')

build() {
  cd "$srcdir/$pkgname-$pkgver/"
  meson setup --prefix /usr --buildtype release _build
  ninja -C _build
}

package() {
  cd "$srcdir/$pkgname-$pkgver/"
  meson install -C _build --destdir "$pkgdir"
}
