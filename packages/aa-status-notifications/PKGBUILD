# Maintainer:  <matto.astro@gmail.com>
pkgname=astroarch-status-notifications
pkgver=0.2.0
pkgrel=1
pkgdesc="Check if there are any announcement to run and show them as desktop notifications"
arch=('aarch64' 'x86_64')
url="https://github.com/devDucks/astroarch-status-notifications"
license=('MIT')
depends=(gcc-libs)
makedepends=(rustup)
install=script.install
source=("https://github.com/devDucks/astroarch-status-notifications/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('42366412863a508832ea23f5ea1f56cd234fe5e7e297a157a9f3ab1f0c1995e9')


build() {
  cd "$srcdir/$pkgname-$pkgver"
  CFLAGS="" CXXFLAGS="" cargo build --release
}

package() {
  mkdir -p $pkgdir/usr/bin/
  mkdir -p $pkgdir/usr/lib/systemd/system
  mkdir -p $pkgdir/usr/share/pixmaps

  install -Dm 755 ${srcdir}/${pkgname}-${pkgver}/target/release/$pkgname ${pkgdir}/usr/bin
  install -Dm 644 ../astroarch.png ${pkgdir}/usr/share/pixmaps/
  install -Dm 644 ../aa_notifications.service ${pkgdir}/usr/lib/systemd/system/
}
