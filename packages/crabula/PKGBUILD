# Maintainer: Mattia Procopio (astro.matto) <matto.astro at gmail dot com>
pkgname=crabula
pkgver=0.1.0
pkgrel=2
pkgdesc="A small and easy FITS viewer"
arch=(x86_64 aarch64)
url=https://github.com/devDucks/crabula
license=(GPLv3)
depends=(gcc-libs)
makedepends=(rustup)
source=(https://github.com/devDucks/crabula/archive/refs/tags/v${pkgver}.tar.gz)
sha256sums=(94d718228ee75d72393a4ff582d6b6497b04dede62e0345f5ff33451f15cfa7d)

build() {
    cd ${srcdir}/crabula-${pkgver}
    # Clear Arch CFLAGS: they are passed to ring's C compiler via the cc crate and
    # cause silent compilation failure on Ubuntu (FORTIFY_SOURCE redefinition +
    # -Werror=format-security). Rust code is unaffected by CFLAGS.
    CFLAGS="" CXXFLAGS="" cargo build --release -p crabula
}

package() {
    mkdir -p ${pkgdir}/usr/bin/
    mkdir -p ${pkgdir}/usr/share/applications
    mkdir -p ${pkgdir}/usr/share/icons/hicolor/scalable/apps/

    install -Dm644 ${srcdir}/crabula-${pkgver}/logo.svg ${pkgdir}/usr/share/icons/hicolor/scalable/apps/crabula.svg
    install -Dm644 ${srcdir}/crabula-${pkgver}/packaging/crabula.desktop ${pkgdir}/usr/share/applications/crabula.desktop
    install -Dm755 ${srcdir}/crabula-${pkgver}/target/release/crabula ${pkgdir}/usr/bin
}
